{
  "name": "storefront",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@neondatabase/serverless": "catalog:",
    "@phosphor-icons/react": "catalog:",
    "@prood/api-client": "workspace:*",
    "@prood/platform": "workspace:*",
    "@prood/types": "workspace:*",
    "@prood/ui": "workspace:*",
    "better-auth": "catalog:",
    "drizzle-orm": "catalog:",
    "next": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "sonner": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@prood/eslint-config": "workspace:^",
    "@prood/typescript-config": "workspace:*",
    "drizzle-kit": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24"
  }
}
