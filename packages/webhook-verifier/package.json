{
  "name": "@commercejs/webhook-verifier",
  "version": "1.1.0",
  "description": "Webhook signature verification with built-in provider formatters",
  "repository": {
    "type": "git",
    "url": "https://github.com/commerce-js/commerce.js.git",
    "directory": "packages/webhook-verifier"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./configs": {
      "import": "./dist/configs/index.js",
      "require": "./dist/configs/index.js",
      "types": "./dist/configs/index.d.ts"
    },
    "./formatters": {
      "import": "./dist/formatters/index.js",
      "require": "./dist/formatters/index.js",
      "types": "./dist/formatters/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run"
  },
  "keywords": [
    "webhook",
    "signature",
    "verification",
    "payments",
    "commercejs"
  ],
  "author": "Baker",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.0",
    "typescript": "^5.7.0"
  }
}
