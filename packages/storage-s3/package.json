{
  "name": "@commercejs/storage-s3",
  "version": "0.2.0",
  "description": "S3-compatible storage provider for CommerceJS — works with AWS S3, Cloudflare R2, DigitalOcean Spaces, MinIO",
  "repository": {
    "type": "git",
    "url": "https://github.com/commerce-js/commerce.js.git",
    "directory": "packages/storage-s3"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@commercejs/types": "workspace:*",
    "aws4fetch": "^1.0.20"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^4.0.0"
  }
}
