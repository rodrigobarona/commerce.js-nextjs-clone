// ---------------------------------------------------------------------------
// Promotion models
// ---------------------------------------------------------------------------

model Promotion {
  id                    String    @id @default(uuid())
  name                  String
  nameAr                String?   @map("name_ar")
  description           String?
  descriptionAr         String?   @map("description_ar")
  discountType          String    @default("percentage") @map("discount_type")
  discountValue         Decimal   @default(0) @map("discount_value") @db.Decimal(12, 2)
  currency              String?
  maxDiscount           Decimal?  @map("max_discount") @db.Decimal(12, 2)
  target                String    @default("order")
  conditions            Json?     @map("conditions_json")
  startsAt              DateTime  @map("starts_at")
  endsAt                DateTime? @map("ends_at")
  isActive              Boolean   @default(true) @map("is_active")
  requiresCoupon        Boolean   @default(false) @map("requires_coupon")
  usageLimitPerCustomer Int?      @map("usage_limit_per_customer")
  usageLimitTotal       Int?      @map("usage_limit_total")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  coupons               Coupon[]

  @@map("promotions")
}

model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  promotionId   String    @map("promotion_id")
  isValid       Boolean   @default(true) @map("is_valid")
  invalidReason String?   @map("invalid_reason")
  timesUsed     Int       @default(0) @map("times_used")

  promotion     Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@map("coupons")
}
