{
  "name": "prood",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "verify": "turbo lint typecheck build",
    "db:migrate": "turbo db:migrate:seed --filter=@prood/platform",
    "db:auth": "pnpm --filter storefront db:push",
    "db:setup": "pnpm db:migrate && pnpm db:auth",
    "env:link": "bash scripts/link-env.sh",
    "catalog:apply": "node scripts/apply-catalog.mjs"
  },
  "devDependencies": {
    "@prood/eslint-config": "workspace:*",
    "@prood/typescript-config": "workspace:*",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=24"
  }
}
